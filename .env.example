# Database (Neon Postgres, or local docker-compose postgres for dev)
DATABASE_URL=postgresql+asyncpg://user:password@host/dbname

# LLM Providers
LLM_PROVIDER=cloud
GEMINI_API_KEY=your_gemini_api_key
GROQ_API_KEY=your_groq_api_key
GEMINI_MODEL=gemini-3.1-flash-lite
GROQ_MODEL=llama-3.1-8b-instant
LMSTUDIO_BASE_URL=http://host.docker.internal:1234/v1
LMSTUDIO_API_KEY=lm-studio
LMSTUDIO_MODEL=qwen/qwen3.5-9b
LMSTUDIO_TIMEOUT_SECONDS=90
GEMINI_TIMEOUT_SECONDS=4
GROQ_TIMEOUT_SECONDS=6
GEMINI_RATE_LIMIT_COOLDOWN_SECONDS=300
LLM_FIRST_INTENT_ENABLED=true

# Image classification (resham.vision) — reuses GEMINI_API_KEY above
GEMINI_VISION_MODEL=gemini-3.1-flash-lite
GEMINI_VISION_TIMEOUT_SECONDS=8
VISION_CLASSIFICATION_BATCH_SIZE=50

# Browser extension (Groq keys stay here; never place one in extension/)
EXTENSION_ALLOWED_ORIGINS=
EXTENSION_REQUEST_TIMEOUT_SECONDS=25
EXTENSION_RANK_CANDIDATE_LIMIT=40
EXTENSION_RESULT_LIMIT=0

# Session cache (ephemeral chat state only — no product cache)
REDIS_URL=redis://default:password@host:port/0
SESSION_STORE_BACKEND=redis
QUERY_CACHE_TTL_HOURS=24

# Vector store (Chroma server mode)
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION_NAME=products_v1
EMBEDDING_MODEL_VERSION=onnx-mini-lm-l6-v2

# Crawler / worker
CRAWL_INTERVAL_HOURS=4
CRAWL_CONCURRENCY=4
CRAWL_MISSING_GRACE_CYCLES=2
SHOPIFY_PRODUCTS_PER_PAGE=250
SHOPIFY_MAX_PAGES_PER_BRAND=50
SHOPIFY_REQUEST_TIMEOUT_SECONDS=10

# Frontend origin (for CORS)
FRONTEND_ORIGIN=http://localhost:3000

# Auth (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
JWT_SECRET_KEY=change_me_to_a_random_secret

# Environment
ENVIRONMENT=development
LOG_LEVEL=info
